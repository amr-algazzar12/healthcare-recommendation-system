# =============================================================================
# .env — Healthcare Recommendation System
# All containers source credentials from here via env_file or interpolation.
# DO NOT COMMIT THIS FILE.  Add .env to .gitignore.
# =============================================================================

# ── Project ──────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=healthcare_rec

# ── PostgreSQL (Airflow metadata + app) ──────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow_secret_2026

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_DB=healthcare
CLICKHOUSE_USER=healthcare_user
CLICKHOUSE_PASSWORD=ch_secret_2026
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1

# ── Hadoop HDFS ───────────────────────────────────────────────────────────────
HDFS_NAMENODE_HOST=namenode
HDFS_NAMENODE_PORT=9001          # native RPC (9000 clashes with CH native port)
HDFS_NAMENODE_HTTP_PORT=9870
HDFS_REPLICATION=1               # single datanode — no replication overhead

# ── YARN ──────────────────────────────────────────────────────────────────────
YARN_RESOURCEMANAGER_HOST=resourcemanager
YARN_RESOURCEMANAGER_PORT=8032
YARN_NODEMANAGER_MEMORY_MB=4096
YARN_NODEMANAGER_VCORES=4

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_MASTER=yarn
SPARK_DEPLOY_MODE=cluster
SPARK_DRIVER_MEMORY=1g
SPARK_EXECUTOR_MEMORY=2g
SPARK_EXECUTOR_CORES=2

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLt0nfdW0M=
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow_secret_2026@postgres:5432/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=healthcare_webserver_secret_2026
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_UID=50000

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5001
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://airflow:airflow_secret_2026@postgres:5432/mlflow
MLFLOW_PORT=5001

# ── Flask API ─────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5050
FLASK_SECRET_KEY=flask_secret_2026

# ── Streamlit ─────────────────────────────────────────────────────────────────
STREAMLIT_PORT=8501

# ── pgAdmin ───────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@healthcare.local
PGADMIN_DEFAULT_PASSWORD=pgadmin_secret_2026
PGADMIN_PORT=5050   # NOTE: pgAdmin shares host 5050, Flask on container-only net; adjust if conflict

# ── Conda ─────────────────────────────────────────────────────────────────────
CONDA_ENV_NAME=healthcare-rec
CONDA_PYTHON_VERSION=3.9
